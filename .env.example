# ============================================
# ЭТО ПРИМЕР ФАЙЛА С НАСТРОЙКАМИ (.env.example)
# Скопируй его в файл ".env" (без .example) и впиши свои настоящие данные.
# Файл .env НИКОГДА не выкладывается в git и не публикуется — там секреты.
# ============================================

# --- Telegram ---
# Токен бота, который тебе дал @BotFather
BOT_TOKEN=123456:AAAA-your-telegram-bot-token

# Telegram ID администраторов бота (через запятую, без пробелов)
# Узнать свой ID можно у бота @userinfobot
ADMIN_IDS=111111111,222222222

# --- PostgreSQL ---
# Строка подключения к базе данных. Формат:
# postgresql+asyncpg://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БАЗЫ
DATABASE_URL=postgresql+asyncpg://astramind:astramind@db:5432/astramind

# --- Redis ---
# Redis используется для антиспам-лимитов (throttling) и кэша
REDIS_URL=redis://redis:6379/0

# --- OpenRouter (мозг бота — LLM) ---
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
# Модель для БЕСПЛАТНЫХ пользователей (первые 10 сообщений) — дешёвая и быстрая,
# чтобы пробный период не сжигал бюджет. Полный список моделей: https://openrouter.ai/models
OPENROUTER_MODEL_FREE=anthropic/claude-3-5-haiku
# Модель для ПОДПИСЧИКОВ — более качественная, это часть ценности платной подписки
OPENROUTER_MODEL_PREMIUM=anthropic/claude-sonnet-4

# --- Tribute.tg (приём платежей за подписку) ---
# Ключ для проверки подписи вебхука (выдаётся в личном кабинете Tribute)
TRIBUTE_API_KEY=tribute_xxxxxxxxxxxxxxxx
TRIBUTE_WEBHOOK_SECRET=your_webhook_signing_secret

# Ссылки на оплату (создаются в кабинете Tribute.tg под каждый тариф)
TRIBUTE_WEEKLY_PAYMENT_URL=https://t.me/tribute/app?startapp=xxxxx_weekly
TRIBUTE_MONTHLY_PAYMENT_URL=https://t.me/tribute/app?startapp=xxxxx_monthly

# --- Настройки продукта ---
# Сколько бесплатных сообщений получает новый пользователь
FREE_MESSAGES_DEFAULT=10
# Сколько бонусных сообщений получает пригласивший за каждого реферала
REFERRAL_BONUS_MESSAGES=5
# Сколько стоят тарифы (только для отображения в боте, реальная сумма настраивается в Tribute)
WEEKLY_PRICE_TEXT=$4.99 / неделя
MONTHLY_PRICE_TEXT=$14.99 / месяц

# --- Rate limit (защита от спама и от резких счетов за API) ---
# Минимальный интервал между сообщениями одного пользователя, в секундах
THROTTLE_RATE_LIMIT=3

# --- Веб-сервер для приёма вебхуков от Tribute.tg ---
WEBHOOK_SERVER_HOST=0.0.0.0
WEBHOOK_SERVER_PORT=8080

# --- Окружение ---
ENVIRONMENT=production
LOG_LEVEL=INFO
