# =====================================================================
# Dockerfile
# =====================================================================
# ЗАЧЕМ ЭТОТ ФАЙЛ (для чайника):
# Docker "упаковывает" наш проект вместе со всем окружением (Python,
# библиотеки) в один переносимый контейнер, который одинаково работает
# и на твоём компьютере, и на Railway/любом сервере.
# =====================================================================

FROM python:3.11-slim

# Отключаем создание .pyc файлов и буферизацию вывода (чтобы логи
# сразу появлялись в stdout, а не копились в буфере)
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Сначала копируем только requirements.txt — так Docker кэширует этот
# слой и не переустанавливает библиотеки заново при каждом изменении кода
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Теперь копируем весь остальной код проекта
COPY . .

# Порт, на котором слушает наш webhook-сервер для платежей (см. .env WEBHOOK_SERVER_PORT)
EXPOSE 8080

CMD ["python", "main.py"]
